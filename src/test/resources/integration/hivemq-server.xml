<?xml version="1.0" encoding="UTF-8"?>
<hivemq>
    <listeners>
        <tls-tcp-listener>
            <port>8883</port>
            <bind-address>0.0.0.0</bind-address>
            <tls>
                <keystore>
                    <path>/opt/hivemq/conf/server-keystore.p12</path>
                    <password>password</password>
                </keystore>
            </tls>
        </tls-tcp-listener>
    </listeners>
</hivemq>
